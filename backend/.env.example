# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/supermart?schema=public"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-64-char-random-string-in-production"
JWT_EXPIRES_IN="7d"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173,https://yourstore.com"

# ─── POS Sync Auth ────────────────────────────────────────────────────────────
# API key for POS terminals — generate with: openssl rand -hex 32
POS_API_KEY="change-this-to-random-32-byte-hex"

# ─── OTP (Simulated in dev — use MSG91 or Twilio in prod) ─────────────────────
SMS_PROVIDER=mock
# MSG91_AUTH_KEY=
# MSG91_SENDER_ID=

# ─── Delivery Fee ─────────────────────────────────────────────────────────────
FREE_DELIVERY_THRESHOLD=500
DELIVERY_FEE=40
