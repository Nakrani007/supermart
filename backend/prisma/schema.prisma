// schema.prisma — Dev: SQLite. Production: switch provider to "postgresql"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── User & Auth ──────────────────────────────────────────────────────────────

model User {
  id         String   @id @default(cuid())
  mobile     String   @unique
  email      String?  @unique
  password   String?
  name       String?
  isVerified Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  orders    Order[]
  otps      OTP[]
  addresses Address[]

  @@index([mobile])
  @@index([email])
  @@index([createdAt])
}

model OTP {
  id        String   @id @default(cuid())
  mobile    String?
  email     String?
  code      String
  type      String   @default("LOGIN")
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [mobile], references: [mobile], onDelete: Cascade)

  @@index([mobile, code, type])
  @@index([email, code, type])
  @@index([expiresAt])
}

// ─── Address Book ─────────────────────────────────────────────────────────────

model Address {
  id        String   @id @default(cuid())
  userId    String
  label     String   @default("Home")
  line1     String
  line2     String?
  city      String
  pincode   String
  landmark  String?
  isDefault Boolean  @default(false)
  lat       Float?   // GPS latitude  — used for delivery zone check
  lng       Float?   // GPS longitude — used for delivery zone check
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Catalog ──────────────────────────────────────────────────────────────────

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  nameHi      String?
  nameGu      String?
  slug        String    @unique
  isVisible   Boolean   @default(true)
  icon        String?
  imageUrl    String?
  sortOrder   Int       @default(0)
  // SEO + discovery fields (optionally auto-generated by admin)
  description String?
  tags        String?   // JSON-encoded string array, e.g. '["fresh","organic"]'
  metaTitle   String?
  products    Product[]

  @@index([isVisible])
  @@index([sortOrder])
}

model Product {
  id            String   @id @default(cuid())
  barcode       String   @unique
  sku           String   @unique
  name          String
  nameHi        String?
  nameGu        String?
  description   String?
  mrp           Float
  discountPrice Float
  stockQty      Int      @default(0)
  unit          String   @default("piece")
  imageUrl      String?
  isActive      Boolean  @default(true)
  isBestSeller  Boolean  @default(false)
  isClearance   Boolean  @default(false)
  isWeeklySaver Boolean  @default(false)
  categoryId    String

  category      Category        @relation(fields: [categoryId], references: [id])
  orderItems    OrderLineItem[]
  storeProducts StoreProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([barcode])
  @@index([sku])
  @@index([categoryId])
  @@index([isActive, stockQty])
  @@index([isBestSeller])
  @@index([isClearance])
  @@index([isWeeklySaver])
  @@index([name])
}

// ─── Delivery Slots ───────────────────────────────────────────────────────────

model DeliverySlot {
  id        String   @id @default(cuid())
  date      DateTime
  startTime String
  endTime   String
  capacity  Int      @default(20)
  booked    Int      @default(0)
  isActive  Boolean  @default(true)

  orders Order[]

  @@unique([date, startTime])
  @@index([date, isActive])
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id              String    @id @default(cuid())
  orderNumber     String    @unique
  userId          String
  status          String    @default("PENDING")
  fulfillmentType String    @default("HOME_DELIVERY")
  deliverySlotId  String?
  address         String?
  subtotal        Float
  discount        Float     @default(0)
  deliveryFee     Float     @default(0)
  total           Float
  notes           String?
  hiddenByUser    Boolean   @default(false)
  // Customer GPS saved at order time (from deliveryLocation in checkout)
  customerLat     Float?
  customerLng     Float?
  // Live delivery tracking — updated by delivery boy / admin during OUT_FOR_DELIVERY
  deliveryLat     Float?
  deliveryLng     Float?
  deliveryLocAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Which store fulfilled / is expected to fulfill this order
  storeId     String?

  user         User           @relation(fields: [userId], references: [id])
  deliverySlot DeliverySlot?  @relation(fields: [deliverySlotId], references: [id])
  store        Store?         @relation(fields: [storeId], references: [id])
  items        OrderLineItem[]

  @@index([userId])
  @@index([userId, hiddenByUser])
  @@index([status])
  @@index([storeId])
  @@index([createdAt])
  @@index([userId, createdAt])
}

model OrderLineItem {
  id            String  @id @default(cuid())
  orderId       String
  productId     String
  quantity      Int
  unitPrice     Float
  mrpAtPurchase Float
  lineTotal     Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

// ─── Banners ──────────────────────────────────────────────────────────────────

model Banner {
  id        String    @id @default(cuid())
  title     String
  subtitle  String?
  imageUrl  String?
  bgColor   String    @default("#0f766e")
  ctaText   String    @default("Shop Now")
  ctaLink   String?
  isActive  Boolean   @default(true)
  startDate DateTime?
  endDate   DateTime?
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([isActive, sortOrder])
}

// ─── Homepage Sections ────────────────────────────────────────────────────────

model HomeSection {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String
  subtitle  String?
  isVisible Boolean  @default(true)
  sortOrder Int      @default(0)
  updatedAt DateTime @updatedAt

  @@index([isVisible])
}

// ─── Delivery Configuration ───────────────────────────────────────────────────

model DeliveryConfig {
  id              String   @id @default(cuid())
  deliveryEnabled Boolean  @default(true)
  pickupEnabled   Boolean  @default(true)
  earliestMsg     String   @default("Delivery in 2-4 hours")
  freeDeliveryMin Float    @default(0)
  deliveryFee     Float    @default(0)
  updatedAt       DateTime @updatedAt
}

// ─── Stores ──────────────────────────────────────────────────────────────────
// Multiple physical stores. isMain = used as the delivery zone origin.

model Store {
  id        String   @id @default(cuid())
  name      String
  address   String
  city      String   @default("Surat")
  state     String   @default("Gujarat")
  pincode   String
  phone     String?
  email     String?
  lat       Float?
  lng       Float?
  openTime  String?  // "09:00"
  closeTime String?  // "21:00"
  isActive  Boolean  @default(true)
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  storeProducts StoreProduct[]
  orders        Order[]

  @@index([isActive])
  @@index([isMain])
}

// ─── Store Inventory ──────────────────────────────────────────────────────────
// Per-store product availability. If no record exists for (storeId, productId),
// falls back to global Product.stockQty for backwards compatibility.

model StoreProduct {
  id            String  @id @default(cuid())
  storeId       String
  productId     String
  stockQty      Int     @default(0)
  isActive      Boolean @default(true)
  mrp           Float?
  discountPrice Float?

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([storeId, productId])
  @@index([storeId])
  @@index([productId])
}

// ─── Delivery Zone ────────────────────────────────────────────────────────────
// Singleton row (id = "singleton") — admin edits radius + pincode whitelist.
// Frontend fetches this to decide checkout eligibility dynamically.

model DeliveryZone {
  id              String   @id @default("singleton")
  radiusKm        Float    @default(5)
  allowedPincodes String   @default("[]")   // JSON string array e.g. '["395001","395002"]'
  storeLat        Float    @default(21.2094)
  storeLng        Float    @default(72.8261)
  storeArea       String   @default("Kapodra, Surat")
  updatedAt       DateTime @updatedAt
}

// ─── Admin ────────────────────────────────────────────────────────────────────

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  name         String   @default("Admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([username])
}
